const express = require("express");
const { crearNotificacion } = require("../Usuario/notificaciones-helper");

function createCompradorCarritoRouter({ pool }) {
	const router = express.Router();

	function obtenerUsuarioSesion(req) {
		return Number(req.session?.usuario_id || 0);
	}

	function requireSession(req, res) {
		const idUsuario = obtenerUsuarioSesion(req);
		if (!Number.isInteger(idUsuario) || idUsuario <= 0) {
			res.status(401).json({ mensaje: "Debes iniciar sesion" });
			return null;
		}
		return idUsuario;
	}

	async function requireActiveSession(req, res) {
		const idUsuario = requireSession(req, res);
		if (!idUsuario) return null;

		try {
			const usuarioActivo = await pool.query(
				`SELECT id
				 FROM usuarios
				 WHERE id = $1
				   AND activo = TRUE
				   AND fecha_eliminacion IS NULL
				 LIMIT 1`,
				[idUsuario]
			);

			if (usuarioActivo.rows.length === 0) {
				return res.status(401).json({ mensaje: "Sesion invalida o usuario inactivo" });
			}

			return idUsuario;
		} catch (error) {
			console.error(error);
			return res.status(500).json({ mensaje: "Error al validar sesion" });
		}
	}

	async function obtenerOCrearCarrito(client, idUsuario) {
		const existente = await client.query(
			"SELECT id FROM carrito WHERE id_usuario = $1 LIMIT 1",
			[idUsuario]
		);

		if (existente.rows.length > 0) {
			return existente.rows[0].id;
		}

		const creado = await client.query(
			"INSERT INTO carrito (id_usuario) VALUES ($1) RETURNING id",
			[idUsuario]
		);

		return creado.rows[0].id;
	}

	async function obtenerDetalleCarrito(idUsuario) {
		const result = await pool.query(
			`SELECT
			   ci.id,
			   ci.cantidad,
			   ci.id_producto,
			   ci.id_servicio,
			   ci.id_agenda_seleccionada,
			   p.nombre AS nombre_producto,
			   p.precio AS precio_producto_original,
			   (SELECT pi.url_imagen FROM producto_imagenes pi WHERE pi.id_producto = p.id ORDER BY pi.es_principal DESC, pi.orden_visual ASC LIMIT 1) AS imagen_producto,
			   LEAST(COALESCE(p.stock_total, 0), COALESCE(lp.stock_lotes, 0)) AS stock_producto,
			   CASE
			     WHEN dp.id IS NOT NULL
			       AND dp.codigo_cupon IS NULL
			       AND CURRENT_TIMESTAMP BETWEEN dp.fecha_inicio AND dp.fecha_fin
			     THEN ROUND((p.precio * (1 - (dp.porcentaje_descuento / 100)))::numeric, 2)
			     ELSE p.precio
			   END AS precio_producto_vigente,
			   s.nombre AS nombre_servicio,
			   s.precio_base AS precio_servicio_original,
			   (SELECT si.url_imagen FROM servicio_imagenes si WHERE si.id_servicio = s.id ORDER BY si.es_principal DESC, si.orden_visual ASC LIMIT 1) AS imagen_servicio,
			   CASE
			     WHEN ds.id IS NOT NULL
			       AND ds.codigo_cupon IS NULL
			       AND CURRENT_TIMESTAMP BETWEEN ds.fecha_inicio AND ds.fecha_fin
			     THEN ROUND((s.precio_base * (1 - (ds.porcentaje_descuento / 100)))::numeric, 2)
			     ELSE s.precio_base
			   END AS precio_servicio_vigente,
			   COALESCE(np.nombre_comercial, ns.nombre_comercial, '') AS empresa,
			   ag.id AS agenda_id,
			   ag.fecha_hora_inicio,
			   ag.fecha_hora_fin,
			   ag.estado AS estado_agenda
			 FROM carrito_items ci
			 INNER JOIN carrito c ON c.id = ci.id_carrito
			 LEFT JOIN productos p ON p.id = ci.id_producto
			 LEFT JOIN descuentos dp ON dp.id = p.id_descuento
			 LEFT JOIN negocios np ON np.id = p.id_negocio
			 LEFT JOIN LATERAL (
			   SELECT COALESCE(SUM(li.stock_disponible), 0)::int AS stock_lotes
			   FROM lotes_inventario li
			   WHERE li.id_producto = p.id
			     AND li.stock_disponible > 0
			     AND (li.fecha_caducidad IS NULL OR li.fecha_caducidad >= CURRENT_DATE)
			 ) lp ON TRUE
			 LEFT JOIN servicios s ON s.id = ci.id_servicio
			 LEFT JOIN descuentos ds ON ds.id = s.id_descuento
			 LEFT JOIN negocios ns ON ns.id = s.id_negocio
			 LEFT JOIN agenda_servicios ag ON ag.id = ci.id_agenda_seleccionada
			 WHERE c.id_usuario = $1
			   AND (ci.id_producto IS NULL OR p.esta_activo = TRUE)
			   AND (ci.id_servicio IS NULL OR s.esta_activo = TRUE)
			 ORDER BY ci.id DESC`,
			[idUsuario]
		);

		const items = result.rows.map((item) => {
			const esProducto = item.id_producto !== null;
			const precioUnitario = esProducto
				? Number(item.precio_producto_vigente || 0)
				: Number(item.precio_servicio_vigente || 0);
			const precioOriginal = esProducto
				? Number(item.precio_producto_original || 0)
				: Number(item.precio_servicio_original || 0);
			const cantidad = Number(item.cantidad);
			const subtotal = precioUnitario * cantidad;

			return {
				id_item: item.id,
				tipo_item: esProducto ? "producto" : "servicio",
				id_producto: item.id_producto,
				id_servicio: item.id_servicio,
				id_agenda_seleccionada: item.id_agenda_seleccionada,
				nombre: esProducto ? item.nombre_producto : item.nombre_servicio,
				empresa: item.empresa,
				cantidad,
				precio_unitario: precioUnitario,
				precio_unitario_original: precioOriginal,
				subtotal,
				imagen: esProducto ? (item.imagen_producto || null) : (item.imagen_servicio || null),
				stock_maximo: esProducto ? Number(item.stock_producto || 0) : 99,
				agenda: item.id_agenda_seleccionada
					? {
						id_agenda: item.agenda_id,
						fecha_hora_inicio: item.fecha_hora_inicio,
						fecha_hora_fin: item.fecha_hora_fin,
						estado: item.estado_agenda,
					}
					: null,
			};
		});

		const total = items.reduce((acum, item) => acum + item.subtotal, 0);

		return {
			total_items: items.length,
			total: Number(total.toFixed(2)),
			items,
		};
	}

	async function obtenerDireccionCheckout(client, idUsuario, idDireccion) {
		const valores = [idUsuario];
		let filtroDireccion = "";

		if (idDireccion !== null) {
			valores.push(idDireccion);
			filtroDireccion = "AND d.id = $2";
		}

		const direccion = await client.query(
			`SELECT
			   d.id,
			   d.calle,
			   d.ciudad,
			   d.estado,
			   d.codigo_postal,
			   d.pais,
			   ST_X(d.geo_location::geometry) AS longitud,
			   ST_Y(d.geo_location::geometry) AS latitud,
			   rud.tipo_direccion,
			   rud.es_principal
			 FROM rel_usuario_direcciones rud
			 INNER JOIN direcciones d ON d.id = rud.id_direccion
			 WHERE rud.id_usuario = $1
			   ${filtroDireccion}
			 ORDER BY rud.es_principal DESC, d.id DESC
			 LIMIT 1`,
			valores
		);

		if (direccion.rows.length === 0) {
			throw new Error("Direccion de envio no encontrada para el usuario");
		}

		const d = direccion.rows[0];
		return {
			id_direccion: d.id,
			calle: d.calle,
			ciudad: d.ciudad,
			estado: d.estado,
			codigo_postal: d.codigo_postal,
			pais: d.pais,
			latitud: d.latitud !== null ? Number(d.latitud) : null,
			longitud: d.longitud !== null ? Number(d.longitud) : null,
			tipo_direccion: d.tipo_direccion,
			es_principal: d.es_principal === true,
		};
	}

	async function obtenerMetodoPagoCheckout(client, idUsuario, idMetodoPago) {
		const valores = [idUsuario];
		let filtroMetodo = "";

		if (idMetodoPago !== null) {
			valores.push(idMetodoPago);
			filtroMetodo = "AND id = $2";
		}

		const metodoPago = await client.query(
			`SELECT
			   id,
			   proveedor_pago,
			   ultimos_cuatro,
			   fecha_expiracion
			 FROM metodos_pago
			 WHERE id_usuario = $1
			   ${filtroMetodo}
			 ORDER BY id DESC
			 LIMIT 1`,
			valores
		);

		if (metodoPago.rows.length === 0) {
			throw new Error("Metodo de pago no encontrado para el usuario");
		}

		const m = metodoPago.rows[0];
		return {
			id_metodo_pago: m.id,
			proveedor_pago: m.proveedor_pago,
			ultimos_cuatro: m.ultimos_cuatro,
			fecha_expiracion: m.fecha_expiracion,
		};
	}

	function normalizarCodigoCupon(valor) {
		const codigo = String(valor || "").trim().toUpperCase();
		return codigo.length > 0 ? codigo : null;
	}

	function calcularPrecioConPorcentaje(precioBase, porcentaje) {
		return Number((Number(precioBase || 0) * (1 - Number(porcentaje || 0) / 100)).toFixed(2));
	}

	function obtenerStockOperable(producto) {
		const stockTotal = Number(producto?.stock_total || 0);
		const stockLotes = Number(producto?.stock_lotes || 0);
		return Math.max(0, Math.min(stockTotal, stockLotes));
	}

	async function obtenerStockProducto(client, idProducto) {
		const result = await client.query(
			`SELECT
			   p.id,
			   p.stock_total,
			   p.esta_activo,
			   COALESCE(l.stock_lotes, 0)::int AS stock_lotes
			 FROM productos p
			 LEFT JOIN LATERAL (
			   SELECT COALESCE(SUM(li.stock_disponible), 0)::int AS stock_lotes
			   FROM lotes_inventario li
			   WHERE li.id_producto = p.id
			     AND li.stock_disponible > 0
			     AND (li.fecha_caducidad IS NULL OR li.fecha_caducidad >= CURRENT_DATE)
			 ) l ON TRUE
			 WHERE p.id = $1
			 LIMIT 1`,
			[idProducto]
		);

		return result.rows[0] || null;
	}

	async function validarNoCompraPropia(client, idUsuario, { idProducto = null, idServicio = null } = {}) {
		let result;
		if (idProducto !== null) {
			result = await client.query(
				`SELECT p.nombre
				 FROM productos p
				 INNER JOIN negocios n ON n.id = p.id_negocio
				 WHERE p.id = $1
				   AND n.id_usuario = $2
				 LIMIT 1`,
				[idProducto, idUsuario]
			);
		} else if (idServicio !== null) {
			result = await client.query(
				`SELECT s.nombre
				 FROM servicios s
				 INNER JOIN negocios n ON n.id = s.id_negocio
				 WHERE s.id = $1
				   AND n.id_usuario = $2
				 LIMIT 1`,
				[idServicio, idUsuario]
			);
		} else {
			return;
		}

		if (result.rows.length > 0) {
			const error = new Error("No puedes comprar tus propios productos o servicios");
			error.statusCode = 403;
			throw error;
		}
	}

	async function validarCarritoSinComprasPropias(client, idUsuario) {
		const result = await client.query(
			`SELECT
			   CASE WHEN ci.id_producto IS NOT NULL THEN 'producto' ELSE 'servicio' END AS tipo,
			   COALESCE(p.nombre, s.nombre, 'item') AS nombre
			 FROM carrito_items ci
			 INNER JOIN carrito c ON c.id = ci.id_carrito
			 LEFT JOIN productos p ON p.id = ci.id_producto
			 LEFT JOIN servicios s ON s.id = ci.id_servicio
			 LEFT JOIN negocios n ON n.id = COALESCE(p.id_negocio, s.id_negocio)
			 WHERE c.id_usuario = $1
			   AND n.id_usuario = $1
			 LIMIT 1`,
			[idUsuario]
		);

		if (result.rows.length > 0) {
			const error = new Error("Tu carrito contiene una publicacion de tu propio negocio");
			error.statusCode = 403;
			throw error;
		}
	}

	async function validarStockProductosCheckout(client, idUsuario) {
		const result = await client.query(
			`SELECT
			   ci.id AS id_item,
			   ci.cantidad,
			   p.id AS id_producto,
			   p.nombre,
			   p.stock_total,
			   p.esta_activo,
			   COALESCE(l.stock_lotes, 0)::int AS stock_lotes
			 FROM carrito_items ci
			 INNER JOIN carrito c ON c.id = ci.id_carrito
			 INNER JOIN productos p ON p.id = ci.id_producto
			 LEFT JOIN LATERAL (
			   SELECT COALESCE(SUM(li.stock_disponible), 0)::int AS stock_lotes
			   FROM lotes_inventario li
			   WHERE li.id_producto = p.id
			     AND li.stock_disponible > 0
			     AND (li.fecha_caducidad IS NULL OR li.fecha_caducidad >= CURRENT_DATE)
			 ) l ON TRUE
			 WHERE c.id_usuario = $1
			   AND ci.id_producto IS NOT NULL
			 ORDER BY ci.id ASC`,
			[idUsuario]
		);

		for (const item of result.rows) {
			if (item.esta_activo !== true) {
				const error = new Error(`El producto ${item.nombre || item.id_producto} ya no esta disponible`);
				error.statusCode = 409;
				throw error;
			}

			const stockDisponible = obtenerStockOperable(item);
			if (Number(item.cantidad || 0) > stockDisponible) {
				const error = new Error(`Stock insuficiente para ${item.nombre || "producto"}; disponible: ${stockDisponible}`);
				error.statusCode = 409;
				throw error;
			}
		}
	}

	async function calcularResumenCheckout(client, idUsuario, codigoCuponRaw = null) {
		const codigoCupon = normalizarCodigoCupon(codigoCuponRaw);
		let cupon = null;

		if (codigoCupon) {
			const cuponResult = await client.query(
				`SELECT id, codigo_cupon, porcentaje_descuento, fecha_inicio, fecha_fin
				 FROM descuentos
				 WHERE UPPER(codigo_cupon) = $1
				   AND CURRENT_TIMESTAMP BETWEEN fecha_inicio AND fecha_fin
				 LIMIT 1`,
				[codigoCupon]
			);

			if (cuponResult.rows.length === 0) {
				const error = new Error("Codigo de cupon invalido o expirado");
				error.statusCode = 404;
				throw error;
			}

			cupon = cuponResult.rows[0];
		}

		const result = await client.query(
			`SELECT
			   ci.id AS id_item,
			   ci.cantidad,
			   ci.id_producto,
			   ci.id_servicio,
			   ci.id_agenda_seleccionada,
			   p.nombre AS nombre_producto,
			   p.precio AS precio_producto,
			   p.esta_activo AS producto_activo,
			   dp.id AS id_descuento_producto,
			   dp.codigo_cupon AS codigo_cupon_producto,
			   dp.porcentaje_descuento AS porcentaje_producto,
			   dp.fecha_inicio AS inicio_producto,
			   dp.fecha_fin AS fin_producto,
			   s.nombre AS nombre_servicio,
			   s.precio_base AS precio_servicio,
			   s.esta_activo AS servicio_activo,
			   ds.id AS id_descuento_servicio,
			   ds.codigo_cupon AS codigo_cupon_servicio,
			   ds.porcentaje_descuento AS porcentaje_servicio,
			   ds.fecha_inicio AS inicio_servicio,
			   ds.fecha_fin AS fin_servicio
			 FROM carrito_items ci
			 INNER JOIN carrito c ON c.id = ci.id_carrito
			 LEFT JOIN productos p ON p.id = ci.id_producto
			 LEFT JOIN descuentos dp ON dp.id = p.id_descuento
			 LEFT JOIN servicios s ON s.id = ci.id_servicio
			 LEFT JOIN descuentos ds ON ds.id = s.id_descuento
			 WHERE c.id_usuario = $1
			   AND (ci.id_producto IS NULL OR p.esta_activo = TRUE)
			   AND (ci.id_servicio IS NULL OR s.esta_activo = TRUE)
			 ORDER BY ci.id ASC`,
			[idUsuario]
		);

		if (result.rows.length === 0) {
			const error = new Error("El carrito esta vacio. No se puede generar un pedido.");
			error.statusCode = 400;
			throw error;
		}

		let subtotal = 0;
		let descuentoAplicado = 0;
		let total = 0;
		const items = [];
		const itemsAfectados = [];

		for (const row of result.rows) {
			const esProducto = row.id_producto !== null;
			const cantidad = Number(row.cantidad || 0);
			const precioBase = esProducto ? Number(row.precio_producto || 0) : Number(row.precio_servicio || 0);
			const descuento = {
				id: esProducto ? row.id_descuento_producto : row.id_descuento_servicio,
				codigo_cupon: esProducto ? row.codigo_cupon_producto : row.codigo_cupon_servicio,
				porcentaje_descuento: esProducto ? row.porcentaje_producto : row.porcentaje_servicio,
				fecha_inicio: esProducto ? row.inicio_producto : row.inicio_servicio,
				fecha_fin: esProducto ? row.fin_producto : row.fin_servicio,
			};

			const descuentoVigente =
				descuento.id !== null &&
				descuento.fecha_inicio &&
				descuento.fecha_fin &&
				new Date() >= new Date(descuento.fecha_inicio) &&
				new Date() <= new Date(descuento.fecha_fin);
			const descuentoAutomatico =
				descuentoVigente && (descuento.codigo_cupon === null || descuento.codigo_cupon === undefined);
			const precioSinCupon = descuentoAutomatico
				? calcularPrecioConPorcentaje(precioBase, descuento.porcentaje_descuento)
				: Number(precioBase.toFixed(2));
			const aplicaCupon =
				cupon !== null &&
				descuentoVigente &&
				Number(descuento.id) === Number(cupon.id) &&
				normalizarCodigoCupon(descuento.codigo_cupon) === codigoCupon;
			const precioFinal = aplicaCupon
				? calcularPrecioConPorcentaje(precioBase, cupon.porcentaje_descuento)
				: precioSinCupon;
			const subtotalItem = Number((precioSinCupon * cantidad).toFixed(2));
			const totalItem = Number((precioFinal * cantidad).toFixed(2));
			const descuentoItem = Number((subtotalItem - totalItem).toFixed(2));
			const itemResumen = {
				id_item: row.id_item,
				tipo_item: esProducto ? "producto" : "servicio",
				id_producto: row.id_producto,
				id_servicio: row.id_servicio,
				id_agenda_seleccionada: row.id_agenda_seleccionada,
				nombre: esProducto ? row.nombre_producto : row.nombre_servicio,
				cantidad,
				precio_unitario_sin_cupon: precioSinCupon,
				precio_unitario_final: precioFinal,
				subtotal: subtotalItem,
				total: totalItem,
				descuento_cupon: descuentoItem,
				cupon_aplicado: aplicaCupon,
			};

			subtotal += subtotalItem;
			descuentoAplicado += descuentoItem;
			total += totalItem;
			items.push(itemResumen);

			if (aplicaCupon) {
				itemsAfectados.push(itemResumen);
			}
		}

		if (cupon && itemsAfectados.length === 0) {
			const error = new Error("El cupon no aplica a los productos o servicios del carrito");
			error.statusCode = 409;
			throw error;
		}

		return {
			codigo_cupon: cupon ? cupon.codigo_cupon : null,
			porcentaje_descuento: cupon ? Number(cupon.porcentaje_descuento) : null,
			subtotal: Number(subtotal.toFixed(2)),
			descuento_aplicado: Number(descuentoAplicado.toFixed(2)),
			total: Number(total.toFixed(2)),
			items,
			items_afectados: itemsAfectados,
		};
	}

	function construirCuponDetalleSnapshot(item, resumenCheckout) {
		if (!item.cupon_aplicado || !resumenCheckout.codigo_cupon) return null;

		return {
			codigo_cupon: resumenCheckout.codigo_cupon,
			porcentaje_descuento: resumenCheckout.porcentaje_descuento,
			descuento_aplicado: item.descuento_cupon,
			precio_sin_cupon: item.precio_unitario_sin_cupon,
			precio_final: item.precio_unitario_final,
			subtotal_sin_cupon: item.subtotal,
			total_con_cupon: item.total,
		};
	}

	async function aplicarPreciosCheckout(client, idPedido, resumenCheckout) {
		for (const item of resumenCheckout.items) {
			const cuponDetalle = construirCuponDetalleSnapshot(item, resumenCheckout);
			const cuponDetalleJson = cuponDetalle ? JSON.stringify(cuponDetalle) : null;

			if (item.tipo_item === "producto") {
				await client.query(
					`UPDATE detalle_pedido
					 SET precio_unitario_historico = $1,
					     snapshot_item = CASE
						     WHEN $4::jsonb IS NULL THEN snapshot_item
						     ELSE COALESCE(snapshot_item, '{}'::jsonb) || jsonb_build_object('cupon', $4::jsonb)
					     END
					 WHERE id_pedido = $2
					   AND id_producto = $3`,
					[item.precio_unitario_final, idPedido, item.id_producto, cuponDetalleJson]
				);
			} else {
				await client.query(
					`UPDATE detalle_pedido
					 SET precio_unitario_historico = $1,
					     snapshot_item = CASE
						     WHEN $5::jsonb IS NULL THEN snapshot_item
						     ELSE COALESCE(snapshot_item, '{}'::jsonb) || jsonb_build_object('cupon', $5::jsonb)
					     END
					 WHERE id_pedido = $2
					   AND id_servicio = $3
					   AND id_agenda_seleccionada = $4`,
					[item.precio_unitario_final, idPedido, item.id_servicio, item.id_agenda_seleccionada, cuponDetalleJson]
				);
			}
		}

		await client.query(
			`UPDATE pedidos
			 SET total = $1
			 WHERE id = $2`,
			[resumenCheckout.total, idPedido]
		);
	}

	// Crear carrito del usuario autenticado (si no existe)
	router.post("/comprador/carrito", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const client = await pool.connect();
		try {
			const idCarrito = await obtenerOCrearCarrito(client, idUsuario);
			return res.status(201).json({ mensaje: "Carrito disponible", id_carrito: idCarrito });
		} catch (error) {
			console.error(error);
			return res.status(500).json({ mensaje: "Error al crear carrito" });
		} finally {
			client.release();
		}
	});

	// Consultar carrito del usuario autenticado
	router.get("/comprador/carrito", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const client = await pool.connect();
		try {
			await obtenerOCrearCarrito(client, idUsuario);
			const carrito = await obtenerDetalleCarrito(idUsuario);
			return res.status(200).json(carrito);
		} catch (error) {
			console.error(error);
			return res.status(500).json({ mensaje: "Error al obtener carrito" });
		} finally {
			client.release();
		}
	});

	// Agregar item al carrito del usuario autenticado
	router.post("/comprador/carrito/items", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const { id_producto, id_servicio, id_agenda_seleccionada, cantidad } = req.body;
		const idProducto = id_producto !== undefined && id_producto !== null ? Number(id_producto) : null;
		const idServicio = id_servicio !== undefined && id_servicio !== null ? Number(id_servicio) : null;
		const idAgenda =
			id_agenda_seleccionada !== undefined && id_agenda_seleccionada !== null
				? Number(id_agenda_seleccionada)
				: null;
		const cantidadNum = Number(cantidad || 1);

		const tieneProducto = Number.isInteger(idProducto) && idProducto > 0;
		const tieneServicio = Number.isInteger(idServicio) && idServicio > 0;

		if (tieneProducto === tieneServicio) {
			return res.status(400).json({ mensaje: "Debes enviar id_producto o id_servicio (solo uno)" });
		}

		if (!Number.isInteger(cantidadNum) || cantidadNum <= 0) {
			return res.status(400).json({ mensaje: "Cantidad invalida" });
		}

		const client = await pool.connect();
		try {
			await client.query("BEGIN");

			const idCarrito = await obtenerOCrearCarrito(client, idUsuario);

			if (tieneProducto) {
				await validarNoCompraPropia(client, idUsuario, { idProducto });
				const producto = await obtenerStockProducto(client, idProducto);
				if (!producto || producto.esta_activo !== true) {
					await client.query("ROLLBACK");
					return res.status(404).json({ mensaje: "Producto no encontrado o inactivo" });
				}
				const stockDisponible = obtenerStockOperable(producto);

				const existente = await client.query(
					`SELECT id, cantidad
					 FROM carrito_items
					 WHERE id_carrito = $1 AND id_producto = $2 AND id_servicio IS NULL
					 LIMIT 1`,
					[idCarrito, idProducto]
				);

				if (existente.rows.length > 0) {
					const nuevaCantidad = Number(existente.rows[0].cantidad) + cantidadNum;
					if (nuevaCantidad > stockDisponible) {
						await client.query("ROLLBACK");
						return res.status(400).json({ mensaje: "Stock insuficiente para la cantidad solicitada" });
					}

					await client.query(
						"UPDATE carrito_items SET cantidad = cantidad + $1 WHERE id = $2",
						[cantidadNum, existente.rows[0].id]
					);
				} else {
					if (cantidadNum > stockDisponible) {
						await client.query("ROLLBACK");
						return res.status(400).json({ mensaje: "Stock insuficiente para la cantidad solicitada" });
					}

					await client.query(
						"INSERT INTO carrito_items (id_carrito, id_producto, cantidad) VALUES ($1, $2, $3)",
						[idCarrito, idProducto, cantidadNum]
					);
				}
			} else {
				if (idAgenda === null) {
					await client.query("ROLLBACK");
					return res.status(400).json({ mensaje: "Selecciona un horario disponible para agendar este servicio" });
				}

				if (cantidadNum !== 1) {
					await client.query("ROLLBACK");
					return res.status(400).json({ mensaje: "Los servicios agendados solo pueden agregarse con cantidad 1" });
				}

				await validarNoCompraPropia(client, idUsuario, { idServicio });
				const servicio = await client.query(
					"SELECT id FROM servicios WHERE id = $1 AND esta_activo = TRUE LIMIT 1",
					[idServicio]
				);
				if (servicio.rows.length === 0) {
					await client.query("ROLLBACK");
					return res.status(404).json({ mensaje: "Servicio no encontrado o inactivo" });
				}

				if (!Number.isInteger(idAgenda) || idAgenda <= 0) {
					await client.query("ROLLBACK");
					return res.status(400).json({ mensaje: "id_agenda_seleccionada invalido" });
				}

				const agenda = await client.query(
					`SELECT id
					 FROM agenda_servicios
					 WHERE id = $1
					   AND id_servicio = $2
					   AND estado = 'disponible'
					   AND fecha_hora_inicio >= CURRENT_TIMESTAMP
					 LIMIT 1`,
					[idAgenda, idServicio]
				);

				if (agenda.rows.length === 0) {
					await client.query("ROLLBACK");
					return res.status(404).json({ mensaje: "Horario no disponible para este servicio" });
				}

				const existente = await client.query(
					`SELECT id
					 FROM carrito_items
					 WHERE id_carrito = $1
					   AND id_servicio = $2
					   AND id_agenda_seleccionada = $3
					 LIMIT 1`,
					[idCarrito, idServicio, idAgenda]
				);

				if (existente.rows.length > 0) {
					await client.query("ROLLBACK");
					return res.status(409).json({ mensaje: "Este horario ya esta en tu carrito" });
				}

				await client.query(
					`INSERT INTO carrito_items (id_carrito, id_servicio, id_agenda_seleccionada, cantidad)
					 VALUES ($1, $2, $3, $4)`,
					[idCarrito, idServicio, idAgenda, cantidadNum]
				);
			}

			await client.query("COMMIT");
			const carrito = await obtenerDetalleCarrito(idUsuario);
			return res.status(201).json({ mensaje: "Item agregado al carrito", carrito });
		} catch (error) {
			await client.query("ROLLBACK");
			if (error.statusCode && Number(error.statusCode) !== 500) {
				return res.status(Number(error.statusCode)).json({ mensaje: error.message });
			}
			console.error(error);
			return res.status(500).json({ mensaje: "Error al agregar item al carrito" });
		} finally {
			client.release();
		}
	});

	// Actualizar item del carrito del usuario autenticado
	router.put("/comprador/carrito/items/:idItem", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const idItem = Number(req.params.idItem);
		if (!Number.isInteger(idItem) || idItem <= 0) {
			return res.status(400).json({ mensaje: "idItem invalido" });
		}

		const { cantidad, id_agenda_seleccionada } = req.body;
		const cantidadNum = Number(cantidad);
		const idAgenda =
			id_agenda_seleccionada !== undefined && id_agenda_seleccionada !== null
				? Number(id_agenda_seleccionada)
				: null;

		if (!Number.isInteger(cantidadNum) || cantidadNum <= 0) {
			return res.status(400).json({ mensaje: "Cantidad invalida" });
		}

		const client = await pool.connect();
		try {
			await client.query("BEGIN");

			const item = await client.query(
				`SELECT ci.id, ci.id_servicio, ci.id_producto
				 FROM carrito_items ci
				 INNER JOIN carrito c ON c.id = ci.id_carrito
				 WHERE ci.id = $1 AND c.id_usuario = $2
				 LIMIT 1`,
				[idItem, idUsuario]
			);

			if (item.rows.length === 0) {
				await client.query("ROLLBACK");
				return res.status(404).json({ mensaje: "Item no encontrado en tu carrito" });
			}

			if (item.rows[0].id_producto !== null) {
				const producto = await obtenerStockProducto(client, item.rows[0].id_producto);

				if (!producto || producto.esta_activo !== true) {
					await client.query("ROLLBACK");
					return res.status(404).json({ mensaje: "Producto no encontrado o inactivo" });
				}

				if (cantidadNum > obtenerStockOperable(producto)) {
					await client.query("ROLLBACK");
					return res.status(400).json({ mensaje: "Stock insuficiente para la cantidad solicitada" });
				}
			}

			if (item.rows[0].id_servicio !== null && cantidadNum !== 1) {
				await client.query("ROLLBACK");
				return res.status(400).json({ mensaje: "Los servicios agendados solo pueden tener cantidad 1" });
			}

			if (item.rows[0].id_servicio !== null && id_agenda_seleccionada !== undefined) {
				if (!Number.isInteger(idAgenda) || idAgenda <= 0) {
					await client.query("ROLLBACK");
					return res.status(400).json({ mensaje: "id_agenda_seleccionada invalido" });
				}

				const agenda = await client.query(
					`SELECT id
					 FROM agenda_servicios
					 WHERE id = $1
					   AND id_servicio = $2
					   AND estado = 'disponible'
					   AND fecha_hora_inicio >= CURRENT_TIMESTAMP
					 LIMIT 1`,
					[idAgenda, item.rows[0].id_servicio]
				);

				if (agenda.rows.length === 0) {
					await client.query("ROLLBACK");
					return res.status(404).json({ mensaje: "Horario no disponible para este servicio" });
				}

				await client.query(
					"UPDATE carrito_items SET cantidad = $1, id_agenda_seleccionada = $2 WHERE id = $3",
					[cantidadNum, idAgenda, idItem]
				);
			} else {
				await client.query("UPDATE carrito_items SET cantidad = $1 WHERE id = $2", [cantidadNum, idItem]);
			}

			await client.query("COMMIT");
			const carrito = await obtenerDetalleCarrito(idUsuario);
			return res.status(200).json({ mensaje: "Item actualizado", carrito });
		} catch (error) {
			await client.query("ROLLBACK");
			console.error(error);
			return res.status(500).json({ mensaje: "Error al actualizar item del carrito" });
		} finally {
			client.release();
		}
	});

	// Eliminar item del carrito del usuario autenticado
	router.delete("/comprador/carrito/items/:idItem", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const idItem = Number(req.params.idItem);
		if (!Number.isInteger(idItem) || idItem <= 0) {
			return res.status(400).json({ mensaje: "idItem invalido" });
		}

		try {
			const eliminado = await pool.query(
				`DELETE FROM carrito_items ci
				 USING carrito c
				 WHERE ci.id = $1
				   AND ci.id_carrito = c.id
				   AND c.id_usuario = $2
				 RETURNING ci.id`,
				[idItem, idUsuario]
			);

			if (eliminado.rows.length === 0) {
				return res.status(404).json({ mensaje: "Item no encontrado en tu carrito" });
			}

			const carrito = await obtenerDetalleCarrito(idUsuario);
			return res.status(200).json({ mensaje: "Item eliminado", carrito });
		} catch (error) {
			console.error(error);
			return res.status(500).json({ mensaje: "Error al eliminar item del carrito" });
		}
	});

	// Vaciar carrito del usuario autenticado
	router.delete("/comprador/carrito", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		try {
			await pool.query(
				`DELETE FROM carrito_items ci
				 USING carrito c
				 WHERE ci.id_carrito = c.id
				   AND c.id_usuario = $1`,
				[idUsuario]
			);

			return res.status(200).json({ mensaje: "Carrito vaciado" });
		} catch (error) {
			console.error(error);
			return res.status(500).json({ mensaje: "Error al vaciar carrito" });
		}
	});

	// Valida y previsualiza un cupon contra el carrito actual.
	router.post("/comprador/carrito/cupon", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const codigoCupon = normalizarCodigoCupon(req.body?.codigo_cupon);
		if (!codigoCupon) {
			return res.status(400).json({ mensaje: "codigo_cupon es obligatorio" });
		}

		const client = await pool.connect();
		try {
			await obtenerOCrearCarrito(client, idUsuario);
			const resumen = await calcularResumenCheckout(client, idUsuario, codigoCupon);
			return res.status(200).json({
				mensaje: "Cupon aplicado correctamente",
				cupon: {
					codigo_cupon: resumen.codigo_cupon,
					porcentaje_descuento: resumen.porcentaje_descuento,
				},
				subtotal: resumen.subtotal,
				descuento_aplicado: resumen.descuento_aplicado,
				total: resumen.total,
				items_afectados: resumen.items_afectados,
			});
		} catch (error) {
			const statusCode = Number(error.statusCode || 500);
			if (statusCode !== 500) {
				return res.status(statusCode).json({ mensaje: error.message });
			}

			console.error(error);
			return res.status(500).json({ mensaje: "Error al validar cupon" });
		} finally {
			client.release();
		}
	});

	// Procesar compra/pedido desde el carrito
	router.post("/comprador/carrito/checkout", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const idDireccion =
			req.body?.id_direccion !== undefined && req.body?.id_direccion !== null
				? Number(req.body.id_direccion)
				: null;
		const idMetodoPago =
			req.body?.id_metodo_pago !== undefined && req.body?.id_metodo_pago !== null
				? Number(req.body.id_metodo_pago)
				: null;
		const codigoCupon = normalizarCodigoCupon(req.body?.codigo_cupon);

		if (idDireccion !== null && (!Number.isInteger(idDireccion) || idDireccion <= 0)) {
			return res.status(400).json({ mensaje: "id_direccion invalido" });
		}

		if (idMetodoPago !== null && (!Number.isInteger(idMetodoPago) || idMetodoPago <= 0)) {
			return res.status(400).json({ mensaje: "id_metodo_pago invalido" });
		}

		const client = await pool.connect();
		try {
			await client.query("BEGIN");

			await obtenerOCrearCarrito(client, idUsuario);
			const resumenCheckout = await calcularResumenCheckout(client, idUsuario, codigoCupon);
			await validarStockProductosCheckout(client, idUsuario);
			await validarCarritoSinComprasPropias(client, idUsuario);

			const direccionSnapshot = await obtenerDireccionCheckout(client, idUsuario, idDireccion);
			const metodoPagoSnapshot = await obtenerMetodoPagoCheckout(client, idUsuario, idMetodoPago);

			const serviciosAgenda = await client.query(
				`SELECT ci.id, ci.id_servicio, ci.id_agenda_seleccionada, s.nombre
				 FROM carrito_items ci
				 INNER JOIN carrito c ON c.id = ci.id_carrito
				 INNER JOIN servicios s ON s.id = ci.id_servicio
				 WHERE c.id_usuario = $1
				   AND ci.id_servicio IS NOT NULL
				 ORDER BY ci.id ASC`,
				[idUsuario]
			);

			const agendaIds = [];
			for (const item of serviciosAgenda.rows) {
				if (!item.id_agenda_seleccionada) {
					await client.query("ROLLBACK");
					return res.status(400).json({
						mensaje: `Selecciona un horario para el servicio ${item.nombre || item.id_servicio}`,
					});
				}

				const agenda = await client.query(
					`SELECT id, id_servicio, estado, fecha_hora_inicio
					 FROM agenda_servicios
					 WHERE id = $1
					 FOR UPDATE`,
					[item.id_agenda_seleccionada]
				);

				if (
					agenda.rows.length === 0 ||
					Number(agenda.rows[0].id_servicio) !== Number(item.id_servicio) ||
					String(agenda.rows[0].estado || "").toLowerCase() !== "disponible" ||
					new Date(agenda.rows[0].fecha_hora_inicio) < new Date()
				) {
					await client.query("ROLLBACK");
					return res.status(409).json({
						mensaje: `El horario seleccionado para ${item.nombre || "este servicio"} ya no esta disponible`,
					});
				}

				agendaIds.push(Number(item.id_agenda_seleccionada));
			}

			const checkoutResult = await client.query(
				"SELECT procesar_checkout($1, $2::jsonb, $3::jsonb) AS id_pedido",
				[idUsuario, direccionSnapshot, metodoPagoSnapshot]
			);

			const idPedido = Number(checkoutResult.rows[0].id_pedido);
			await aplicarPreciosCheckout(client, idPedido, resumenCheckout);

			const agendaIdsUnicos = [...new Set(agendaIds)];
			if (agendaIdsUnicos.length > 0) {
				await client.query(
					`UPDATE agenda_servicios
					 SET estado = 'reservado',
					     id_usuario_cliente = $1
					 WHERE id = ANY($2::int[])`,
					[idUsuario, agendaIdsUnicos]
				);
			}

			const pedidoResult = await client.query(
				`SELECT id, total, estado_pedido, fecha_pedido
				 FROM pedidos
				 WHERE id = $1
				 LIMIT 1`,
				[idPedido]
			);

			await client.query("COMMIT");

			// ── Notificaciones in-app (fire-and-forget, no bloquean la respuesta) ──
			const totalFormateado = `$${Number(pedidoResult.rows[0]?.total || resumenCheckout.total).toFixed(2)}`;
			crearNotificacion(pool, {
				id_usuario: idUsuario,
				tipo: "pedido_confirmado",
				titulo: "Pedido confirmado",
				mensaje: `Tu pedido por ${totalFormateado} fue confirmado exitosamente.`,
				datos_extra: { pedido_id: idPedido, url: `/mis-compras/${idPedido}` },
			});

			// Notificar a los vendedores afectados
			pool.query(
				`SELECT DISTINCT n.id_usuario
				 FROM detalle_pedido dp
				 LEFT JOIN productos p ON p.id = dp.id_producto
				 LEFT JOIN servicios s ON s.id = dp.id_servicio
				 LEFT JOIN negocios n ON n.id = COALESCE(p.id_negocio, s.id_negocio)
				 WHERE dp.id_pedido = $1 AND n.id_usuario IS NOT NULL`,
				[idPedido]
			).then((vendedoresResult) => {
				for (const row of vendedoresResult.rows) {
					crearNotificacion(pool, {
						id_usuario: row.id_usuario,
						tipo: "nuevo_pedido",
						titulo: "Nuevo pedido recibido",
						mensaje: `Recibiste un nuevo pedido por ${totalFormateado}.`,
						datos_extra: { pedido_id: idPedido, url: `/vendedor/pedidos` },
					});
				}
			}).catch((err) => console.error("[notif] Error al notificar vendedores:", err.message));

			if (pedidoResult.rows.length === 0) {
				return res.status(201).json({
					mensaje: "Pedido generado correctamente",
					id_pedido: idPedido,
				});
			}

			const pedido = pedidoResult.rows[0];
			return res.status(201).json({
				mensaje: "Pedido generado correctamente",
					pedido: {
						id: pedido.id,
						total: Number(pedido.total),
						estado_pedido: pedido.estado_pedido,
						fecha_pedido: pedido.fecha_pedido,
					},
					cupon: resumenCheckout.codigo_cupon
						? {
							codigo_cupon: resumenCheckout.codigo_cupon,
							porcentaje_descuento: resumenCheckout.porcentaje_descuento,
							descuento_aplicado: resumenCheckout.descuento_aplicado,
						}
						: null,
				});
		} catch (error) {
			await client.query("ROLLBACK");
			console.error(error);

			if (error && typeof error.message === "string") {
				if (error.message.includes("carrito está vacío") || error.message.includes("carrito activo")) {
					return res.status(400).json({ mensaje: error.message });
				}

				if (error.message.includes("Stock insuficiente")) {
					return res.status(409).json({ mensaje: error.message });
				}

				if (error.statusCode && Number(error.statusCode) !== 500) {
					return res.status(Number(error.statusCode)).json({ mensaje: error.message });
				}
			}

			return res.status(500).json({ mensaje: "Error al procesar checkout" });
		} finally {
			client.release();
		}
	});

	return router;
}

module.exports = createCompradorCarritoRouter;

const express = require("express");

function createCompradorCarritoRouter({ pool }) {
	const router = express.Router();

	function obtenerUsuarioSesion(req) {
		return Number(req.session?.usuario_id || 0);
	}

	function requireSession(req, res) {
		const idUsuario = obtenerUsuarioSesion(req);
		if (!Number.isInteger(idUsuario) || idUsuario <= 0) {
			res.status(401).json({ mensaje: "Debes iniciar sesion" });
			return null;
		}
		return idUsuario;
	}

	async function requireActiveSession(req, res) {
		const idUsuario = requireSession(req, res);
		if (!idUsuario) return null;

		try {
			const usuarioActivo = await pool.query(
				`SELECT id
				 FROM usuarios
				 WHERE id = $1
				   AND activo = TRUE
				   AND fecha_eliminacion IS NULL
				 LIMIT 1`,
				[idUsuario]
			);

			if (usuarioActivo.rows.length === 0) {
				return res.status(401).json({ mensaje: "Sesion invalida o usuario inactivo" });
			}

			return idUsuario;
		} catch (error) {
			console.error(error);
			return res.status(500).json({ mensaje: "Error al validar sesion" });
		}
	}

	async function obtenerOCrearCarrito(client, idUsuario) {
		const existente = await client.query(
			"SELECT id FROM carrito WHERE id_usuario = $1 LIMIT 1",
			[idUsuario]
		);

		if (existente.rows.length > 0) {
			return existente.rows[0].id;
		}

		const creado = await client.query(
			"INSERT INTO carrito (id_usuario) VALUES ($1) RETURNING id",
			[idUsuario]
		);

		return creado.rows[0].id;
	}

	async function obtenerDetalleCarrito(idUsuario) {
		const result = await pool.query(
			`SELECT
			   ci.id,
			   ci.cantidad,
			   ci.id_producto,
			   ci.id_servicio,
			   ci.id_agenda_seleccionada,
			   p.nombre AS nombre_producto,
			   p.precio AS precio_producto_original,
			   (SELECT pi.url_imagen FROM producto_imagenes pi WHERE pi.id_producto = p.id ORDER BY pi.es_principal DESC, pi.orden_visual ASC LIMIT 1) AS imagen_producto,
			   p.stock_total AS stock_producto,
			   CASE
			     WHEN dp.id IS NOT NULL
			       AND dp.codigo_cupon IS NULL
			       AND CURRENT_TIMESTAMP BETWEEN dp.fecha_inicio AND dp.fecha_fin
			     THEN ROUND((p.precio * (1 - (dp.porcentaje_descuento / 100)))::numeric, 2)
			     ELSE p.precio
			   END AS precio_producto_vigente,
			   s.nombre AS nombre_servicio,
			   s.precio_base AS precio_servicio_original,
			   (SELECT si.url_imagen FROM servicio_imagenes si WHERE si.id_servicio = s.id ORDER BY si.es_principal DESC, si.orden_visual ASC LIMIT 1) AS imagen_servicio,
			   CASE
			     WHEN ds.id IS NOT NULL
			       AND ds.codigo_cupon IS NULL
			       AND CURRENT_TIMESTAMP BETWEEN ds.fecha_inicio AND ds.fecha_fin
			     THEN ROUND((s.precio_base * (1 - (ds.porcentaje_descuento / 100)))::numeric, 2)
			     ELSE s.precio_base
			   END AS precio_servicio_vigente,
			   COALESCE(np.nombre_comercial, ns.nombre_comercial, '') AS empresa,
			   ag.fecha_hora_inicio,
			   ag.fecha_hora_fin,
			   ag.estado AS estado_agenda
			 FROM carrito_items ci
			 INNER JOIN carrito c ON c.id = ci.id_carrito
			 LEFT JOIN productos p ON p.id = ci.id_producto
			 LEFT JOIN descuentos dp ON dp.id = p.id_descuento
			 LEFT JOIN negocios np ON np.id = p.id_negocio
			 LEFT JOIN servicios s ON s.id = ci.id_servicio
			 LEFT JOIN descuentos ds ON ds.id = s.id_descuento
			 LEFT JOIN negocios ns ON ns.id = s.id_negocio
			 LEFT JOIN agenda_servicios ag ON ag.id = ci.id_agenda_seleccionada
			 WHERE c.id_usuario = $1
			   AND (ci.id_producto IS NULL OR p.esta_activo = TRUE)
			   AND (ci.id_servicio IS NULL OR s.esta_activo = TRUE)
			 ORDER BY ci.id DESC`,
			[idUsuario]
		);

		const items = result.rows.map((item) => {
			const esProducto = item.id_producto !== null;
			const precioUnitario = esProducto
				? Number(item.precio_producto_vigente || 0)
				: Number(item.precio_servicio_vigente || 0);
			const precioOriginal = esProducto
				? Number(item.precio_producto_original || 0)
				: Number(item.precio_servicio_original || 0);
			const cantidad = Number(item.cantidad);
			const subtotal = precioUnitario * cantidad;

			return {
				id_item: item.id,
				tipo_item: esProducto ? "producto" : "servicio",
				id_producto: item.id_producto,
				id_servicio: item.id_servicio,
				id_agenda_seleccionada: item.id_agenda_seleccionada,
				nombre: esProducto ? item.nombre_producto : item.nombre_servicio,
				empresa: item.empresa,
				cantidad,
				precio_unitario: precioUnitario,
				precio_unitario_original: precioOriginal,
				subtotal,
				imagen: esProducto ? (item.imagen_producto || null) : (item.imagen_servicio || null),
				stock_maximo: esProducto ? Number(item.stock_producto || 0) : 99,
				agenda: item.id_agenda_seleccionada
					? {
						fecha_hora_inicio: item.fecha_hora_inicio,
						fecha_hora_fin: item.fecha_hora_fin,
						estado: item.estado_agenda,
					}
					: null,
			};
		});

		const total = items.reduce((acum, item) => acum + item.subtotal, 0);

		return {
			total_items: items.length,
			total: Number(total.toFixed(2)),
			items,
		};
	}

	async function obtenerDireccionCheckout(client, idUsuario, idDireccion) {
		const valores = [idUsuario];
		let filtroDireccion = "";

		if (idDireccion !== null) {
			valores.push(idDireccion);
			filtroDireccion = "AND d.id = $2";
		}

		const direccion = await client.query(
			`SELECT
			   d.id,
			   d.calle,
			   d.ciudad,
			   d.estado,
			   d.codigo_postal,
			   d.pais,
			   ST_X(d.geo_location::geometry) AS longitud,
			   ST_Y(d.geo_location::geometry) AS latitud,
			   rud.tipo_direccion,
			   rud.es_principal
			 FROM rel_usuario_direcciones rud
			 INNER JOIN direcciones d ON d.id = rud.id_direccion
			 WHERE rud.id_usuario = $1
			   ${filtroDireccion}
			 ORDER BY rud.es_principal DESC, d.id DESC
			 LIMIT 1`,
			valores
		);

		if (direccion.rows.length === 0) {
			throw new Error("Direccion de envio no encontrada para el usuario");
		}

		const d = direccion.rows[0];
		return {
			id_direccion: d.id,
			calle: d.calle,
			ciudad: d.ciudad,
			estado: d.estado,
			codigo_postal: d.codigo_postal,
			pais: d.pais,
			latitud: d.latitud !== null ? Number(d.latitud) : null,
			longitud: d.longitud !== null ? Number(d.longitud) : null,
			tipo_direccion: d.tipo_direccion,
			es_principal: d.es_principal === true,
		};
	}

	async function obtenerMetodoPagoCheckout(client, idUsuario, idMetodoPago) {
		const valores = [idUsuario];
		let filtroMetodo = "";

		if (idMetodoPago !== null) {
			valores.push(idMetodoPago);
			filtroMetodo = "AND id = $2";
		}

		const metodoPago = await client.query(
			`SELECT
			   id,
			   proveedor_pago,
			   ultimos_cuatro,
			   fecha_expiracion
			 FROM metodos_pago
			 WHERE id_usuario = $1
			   ${filtroMetodo}
			 ORDER BY id DESC
			 LIMIT 1`,
			valores
		);

		if (metodoPago.rows.length === 0) {
			throw new Error("Metodo de pago no encontrado para el usuario");
		}

		const m = metodoPago.rows[0];
		return {
			id_metodo_pago: m.id,
			proveedor_pago: m.proveedor_pago,
			ultimos_cuatro: m.ultimos_cuatro,
			fecha_expiracion: m.fecha_expiracion,
		};
	}

	// Crear carrito del usuario autenticado (si no existe)
	router.post("/comprador/carrito", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const client = await pool.connect();
		try {
			const idCarrito = await obtenerOCrearCarrito(client, idUsuario);
			return res.status(201).json({ mensaje: "Carrito disponible", id_carrito: idCarrito });
		} catch (error) {
			console.error(error);
			return res.status(500).json({ mensaje: "Error al crear carrito" });
		} finally {
			client.release();
		}
	});

	// Consultar carrito del usuario autenticado
	router.get("/comprador/carrito", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const client = await pool.connect();
		try {
			await obtenerOCrearCarrito(client, idUsuario);
			const carrito = await obtenerDetalleCarrito(idUsuario);
			return res.status(200).json(carrito);
		} catch (error) {
			console.error(error);
			return res.status(500).json({ mensaje: "Error al obtener carrito" });
		} finally {
			client.release();
		}
	});

	// Agregar item al carrito del usuario autenticado
	router.post("/comprador/carrito/items", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const { id_producto, id_servicio, id_agenda_seleccionada, cantidad } = req.body;
		const idProducto = id_producto !== undefined && id_producto !== null ? Number(id_producto) : null;
		const idServicio = id_servicio !== undefined && id_servicio !== null ? Number(id_servicio) : null;
		const idAgenda =
			id_agenda_seleccionada !== undefined && id_agenda_seleccionada !== null
				? Number(id_agenda_seleccionada)
				: null;
		const cantidadNum = Number(cantidad || 1);

		const tieneProducto = Number.isInteger(idProducto) && idProducto > 0;
		const tieneServicio = Number.isInteger(idServicio) && idServicio > 0;

		if (tieneProducto === tieneServicio) {
			return res.status(400).json({ mensaje: "Debes enviar id_producto o id_servicio (solo uno)" });
		}

		if (!Number.isInteger(cantidadNum) || cantidadNum <= 0) {
			return res.status(400).json({ mensaje: "Cantidad invalida" });
		}

		const client = await pool.connect();
		try {
			await client.query("BEGIN");

			const idCarrito = await obtenerOCrearCarrito(client, idUsuario);

			if (tieneProducto) {
				const producto = await client.query(
					"SELECT id, stock_total FROM productos WHERE id = $1 AND esta_activo = TRUE LIMIT 1",
					[idProducto]
				);
				if (producto.rows.length === 0) {
					await client.query("ROLLBACK");
					return res.status(404).json({ mensaje: "Producto no encontrado o inactivo" });
				}

				const existente = await client.query(
					`SELECT id, cantidad
					 FROM carrito_items
					 WHERE id_carrito = $1 AND id_producto = $2 AND id_servicio IS NULL
					 LIMIT 1`,
					[idCarrito, idProducto]
				);

				if (existente.rows.length > 0) {
					const nuevaCantidad = Number(existente.rows[0].cantidad) + cantidadNum;
					if (nuevaCantidad > Number(producto.rows[0].stock_total || 0)) {
						await client.query("ROLLBACK");
						return res.status(400).json({ mensaje: "Stock insuficiente para la cantidad solicitada" });
					}

					await client.query(
						"UPDATE carrito_items SET cantidad = cantidad + $1 WHERE id = $2",
						[cantidadNum, existente.rows[0].id]
					);
				} else {
					if (cantidadNum > Number(producto.rows[0].stock_total || 0)) {
						await client.query("ROLLBACK");
						return res.status(400).json({ mensaje: "Stock insuficiente para la cantidad solicitada" });
					}

					await client.query(
						"INSERT INTO carrito_items (id_carrito, id_producto, cantidad) VALUES ($1, $2, $3)",
						[idCarrito, idProducto, cantidadNum]
					);
				}
			} else {
				const servicio = await client.query(
					"SELECT id FROM servicios WHERE id = $1 AND esta_activo = TRUE LIMIT 1",
					[idServicio]
				);
				if (servicio.rows.length === 0) {
					await client.query("ROLLBACK");
					return res.status(404).json({ mensaje: "Servicio no encontrado o inactivo" });
				}

				if (idAgenda !== null) {
					if (!Number.isInteger(idAgenda) || idAgenda <= 0) {
						await client.query("ROLLBACK");
						return res.status(400).json({ mensaje: "id_agenda_seleccionada invalido" });
					}

					const agenda = await client.query(
						`SELECT id
						 FROM agenda_servicios
						 WHERE id = $1 AND id_servicio = $2 AND estado = 'disponible'
						 LIMIT 1`,
						[idAgenda, idServicio]
					);

					if (agenda.rows.length === 0) {
						await client.query("ROLLBACK");
						return res.status(404).json({ mensaje: "Agenda no encontrada para este servicio" });
					}
				}

				await client.query(
					`INSERT INTO carrito_items (id_carrito, id_servicio, id_agenda_seleccionada, cantidad)
					 VALUES ($1, $2, $3, $4)`,
					[idCarrito, idServicio, idAgenda, cantidadNum]
				);
			}

			await client.query("COMMIT");
			const carrito = await obtenerDetalleCarrito(idUsuario);
			return res.status(201).json({ mensaje: "Item agregado al carrito", carrito });
		} catch (error) {
			await client.query("ROLLBACK");
			console.error(error);
			return res.status(500).json({ mensaje: "Error al agregar item al carrito" });
		} finally {
			client.release();
		}
	});

	// Actualizar item del carrito del usuario autenticado
	router.put("/comprador/carrito/items/:idItem", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const idItem = Number(req.params.idItem);
		if (!Number.isInteger(idItem) || idItem <= 0) {
			return res.status(400).json({ mensaje: "idItem invalido" });
		}

		const { cantidad, id_agenda_seleccionada } = req.body;
		const cantidadNum = Number(cantidad);
		const idAgenda =
			id_agenda_seleccionada !== undefined && id_agenda_seleccionada !== null
				? Number(id_agenda_seleccionada)
				: null;

		if (!Number.isInteger(cantidadNum) || cantidadNum <= 0) {
			return res.status(400).json({ mensaje: "Cantidad invalida" });
		}

		const client = await pool.connect();
		try {
			await client.query("BEGIN");

			const item = await client.query(
				`SELECT ci.id, ci.id_servicio, ci.id_producto
				 FROM carrito_items ci
				 INNER JOIN carrito c ON c.id = ci.id_carrito
				 WHERE ci.id = $1 AND c.id_usuario = $2
				 LIMIT 1`,
				[idItem, idUsuario]
			);

			if (item.rows.length === 0) {
				await client.query("ROLLBACK");
				return res.status(404).json({ mensaje: "Item no encontrado en tu carrito" });
			}

			if (item.rows[0].id_producto !== null) {
				const producto = await client.query(
					"SELECT stock_total, esta_activo FROM productos WHERE id = $1 LIMIT 1",
					[item.rows[0].id_producto]
				);

				if (producto.rows.length === 0 || producto.rows[0].esta_activo !== true) {
					await client.query("ROLLBACK");
					return res.status(404).json({ mensaje: "Producto no encontrado o inactivo" });
				}

				if (cantidadNum > Number(producto.rows[0].stock_total || 0)) {
					await client.query("ROLLBACK");
					return res.status(400).json({ mensaje: "Stock insuficiente para la cantidad solicitada" });
				}
			}

			if (item.rows[0].id_servicio !== null && id_agenda_seleccionada !== undefined) {
				if (idAgenda !== null && (!Number.isInteger(idAgenda) || idAgenda <= 0)) {
					await client.query("ROLLBACK");
					return res.status(400).json({ mensaje: "id_agenda_seleccionada invalido" });
				}

				if (idAgenda !== null) {
					const agenda = await client.query(
						`SELECT id
						 FROM agenda_servicios
						 WHERE id = $1 AND id_servicio = $2 AND estado = 'disponible'
						 LIMIT 1`,
						[idAgenda, item.rows[0].id_servicio]
					);

					if (agenda.rows.length === 0) {
						await client.query("ROLLBACK");
						return res.status(404).json({ mensaje: "Agenda no encontrada para este servicio" });
					}
				}

				await client.query(
					"UPDATE carrito_items SET cantidad = $1, id_agenda_seleccionada = $2 WHERE id = $3",
					[cantidadNum, idAgenda, idItem]
				);
			} else {
				await client.query("UPDATE carrito_items SET cantidad = $1 WHERE id = $2", [cantidadNum, idItem]);
			}

			await client.query("COMMIT");
			const carrito = await obtenerDetalleCarrito(idUsuario);
			return res.status(200).json({ mensaje: "Item actualizado", carrito });
		} catch (error) {
			await client.query("ROLLBACK");
			console.error(error);
			return res.status(500).json({ mensaje: "Error al actualizar item del carrito" });
		} finally {
			client.release();
		}
	});

	// Eliminar item del carrito del usuario autenticado
	router.delete("/comprador/carrito/items/:idItem", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const idItem = Number(req.params.idItem);
		if (!Number.isInteger(idItem) || idItem <= 0) {
			return res.status(400).json({ mensaje: "idItem invalido" });
		}

		try {
			const eliminado = await pool.query(
				`DELETE FROM carrito_items ci
				 USING carrito c
				 WHERE ci.id = $1
				   AND ci.id_carrito = c.id
				   AND c.id_usuario = $2
				 RETURNING ci.id`,
				[idItem, idUsuario]
			);

			if (eliminado.rows.length === 0) {
				return res.status(404).json({ mensaje: "Item no encontrado en tu carrito" });
			}

			const carrito = await obtenerDetalleCarrito(idUsuario);
			return res.status(200).json({ mensaje: "Item eliminado", carrito });
		} catch (error) {
			console.error(error);
			return res.status(500).json({ mensaje: "Error al eliminar item del carrito" });
		}
	});

	// Vaciar carrito del usuario autenticado
	router.delete("/comprador/carrito", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		try {
			await pool.query(
				`DELETE FROM carrito_items ci
				 USING carrito c
				 WHERE ci.id_carrito = c.id
				   AND c.id_usuario = $1`,
				[idUsuario]
			);

			return res.status(200).json({ mensaje: "Carrito vaciado" });
		} catch (error) {
			console.error(error);
			return res.status(500).json({ mensaje: "Error al vaciar carrito" });
		}
	});

	// Procesar compra/pedido desde el carrito
	router.post("/comprador/carrito/checkout", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const idDireccion =
			req.body?.id_direccion !== undefined && req.body?.id_direccion !== null
				? Number(req.body.id_direccion)
				: null;
		const idMetodoPago =
			req.body?.id_metodo_pago !== undefined && req.body?.id_metodo_pago !== null
				? Number(req.body.id_metodo_pago)
				: null;

		if (idDireccion !== null && (!Number.isInteger(idDireccion) || idDireccion <= 0)) {
			return res.status(400).json({ mensaje: "id_direccion invalido" });
		}

		if (idMetodoPago !== null && (!Number.isInteger(idMetodoPago) || idMetodoPago <= 0)) {
			return res.status(400).json({ mensaje: "id_metodo_pago invalido" });
		}

		const client = await pool.connect();
		try {
			await client.query("BEGIN");

			await obtenerOCrearCarrito(client, idUsuario);

			const direccionSnapshot = await obtenerDireccionCheckout(client, idUsuario, idDireccion);
			const metodoPagoSnapshot = await obtenerMetodoPagoCheckout(client, idUsuario, idMetodoPago);

			const checkoutResult = await client.query(
				"SELECT procesar_checkout($1, $2::jsonb, $3::jsonb) AS id_pedido",
				[idUsuario, direccionSnapshot, metodoPagoSnapshot]
			);

			const idPedido = Number(checkoutResult.rows[0].id_pedido);

			const pedidoResult = await client.query(
				`SELECT id, total, estado_pedido, fecha_pedido
				 FROM pedidos
				 WHERE id = $1
				 LIMIT 1`,
				[idPedido]
			);

			await client.query("COMMIT");

			if (pedidoResult.rows.length === 0) {
				return res.status(201).json({
					mensaje: "Pedido generado correctamente",
					id_pedido: idPedido,
				});
			}

			const pedido = pedidoResult.rows[0];
			return res.status(201).json({
				mensaje: "Pedido generado correctamente",
				pedido: {
					id: pedido.id,
					total: Number(pedido.total),
					estado_pedido: pedido.estado_pedido,
					fecha_pedido: pedido.fecha_pedido,
				},
			});
		} catch (error) {
			await client.query("ROLLBACK");
			console.error(error);

			if (error && typeof error.message === "string") {
				if (error.message.includes("carrito está vacío") || error.message.includes("carrito activo")) {
					return res.status(400).json({ mensaje: error.message });
				}

				if (error.message.includes("Stock insuficiente")) {
					return res.status(409).json({ mensaje: error.message });
				}
			}

			return res.status(500).json({ mensaje: "Error al procesar checkout" });
		} finally {
			client.release();
		}
	});

	return router;
}

module.exports = createCompradorCarritoRouter;

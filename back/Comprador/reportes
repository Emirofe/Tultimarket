const express = require("express");
const { intentarEnviarCorreos } = require("../Admin/mail");
const { notificarMultiples } = require("../Usuario/notificaciones-helper");

function createCompradorReportesRouter({ pool }) {
	const router = express.Router();

	// Obtiene el id del usuario guardado en la sesion.
	function obtenerUsuarioSesion(req) {
		return Number(req.session?.usuario_id || 0);
	}

	// Valida que exista sesion activa y que el usuario siga habilitado en la base.
	async function requireActiveSession(req, res) {
		const idUsuario = obtenerUsuarioSesion(req);
		if (!Number.isInteger(idUsuario) || idUsuario <= 0) {
			res.status(401).json({ mensaje: "Debes iniciar sesion" });
			return null;
		}

		try {
			const result = await pool.query(
				`SELECT id
				 FROM usuarios
				 WHERE id = $1
					 AND activo = TRUE
					 AND fecha_eliminacion IS NULL
				 LIMIT 1`,
				[idUsuario]
			);

			if (result.rows.length === 0) {
				res.status(401).json({ mensaje: "Sesion invalida o usuario inactivo" });
				return null;
			}

			return idUsuario;
		} catch (error) {
			console.error(error);
			res.status(500).json({ mensaje: "Error al validar sesion" });
			return null;
		}
	}

	// Busca el negocio dueño de un producto para amarrar el reporte al contexto correcto.
	async function obtenerNegocioPorProducto(idProducto) {
		const result = await pool.query(
			`SELECT id, id_negocio
			 FROM productos
			 WHERE id = $1
			 LIMIT 1`,
			[idProducto]
		);

		return result.rows[0] || null;
	}

	// Busca el negocio dueño de un servicio para relacionarlo con el reporte.
	async function obtenerNegocioPorServicio(idServicio) {
		const result = await pool.query(
			`SELECT id, id_negocio
			 FROM servicios
			 WHERE id = $1
			 LIMIT 1`,
			[idServicio]
		);

		return result.rows[0] || null;
	}

	function escapeHtml(valor) {
		return String(valor ?? "")
			.replace(/&/g, "&amp;")
			.replace(/</g, "&lt;")
			.replace(/>/g, "&gt;")
			.replace(/"/g, "&quot;")
			.replace(/'/g, "&#039;");
	}

	function construirTicketReporte(idReporte) {
		return `RPT-${String(idReporte).padStart(6, "0")}`;
	}

	function obtenerCorreosModeracionEnv() {
		return String(process.env.ADMIN_NOTIFICATION_EMAILS || process.env.ADMIN_EMAILS || "")
			.split(/[;,]/)
			.map((email) => email.trim())
			.filter((email) => email.length > 0);
	}

	async function obtenerContextoReporte(idReporte) {
		const result = await pool.query(
			`SELECT
				 r.id,
				 r.id_usuario AS id_reportante,
				 r.id_negocio,
				 r.id_producto,
				 r.id_servicio,
				 r.motivo,
				 r.descripcion,
				 r.estado_reporte,
				 r.fecha_creacion,
				 ur.nombre AS reportante_nombre,
				 ur.email AS reportante_email,
				 n.nombre_comercial,
				 uv.id AS id_usuario_reportado,
				 uv.nombre AS usuario_reportado_nombre,
				 uv.email AS usuario_reportado_email,
				 p.nombre AS nombre_producto,
				 s.nombre AS nombre_servicio
			 FROM reportes r
			 INNER JOIN usuarios ur ON ur.id = r.id_usuario
			 INNER JOIN negocios n ON n.id = r.id_negocio
			 INNER JOIN usuarios uv ON uv.id = n.id_usuario
			 LEFT JOIN productos p ON p.id = r.id_producto
			 LEFT JOIN servicios s ON s.id = r.id_servicio
			 WHERE r.id = $1
			 LIMIT 1`,
			[idReporte]
		);

		return result.rows[0] || null;
	}

	async function obtenerCorreosModeracion() {
		const correosEnv = obtenerCorreosModeracionEnv();

		try {
			const result = await pool.query(
				`SELECT u.email
				 FROM usuarios u
				 INNER JOIN roles r ON r.id = u.id_rol
				 WHERE u.activo = TRUE
				   AND u.fecha_eliminacion IS NULL
				   AND u.email IS NOT NULL
				   AND TRIM(u.email) <> ''
				   AND LOWER(r.nombre_rol) = 'admin'
				 ORDER BY u.id ASC`
			);

			return [...new Set([...correosEnv, ...result.rows.map((row) => row.email)])];
		} catch (error) {
			console.error("No se pudieron obtener correos admin para notificar reporte:", error);
			return correosEnv;
		}
	}

	async function notificarModeracionReporteCreado(idReporte) {
		const contexto = await obtenerContextoReporte(idReporte);
		if (!contexto) {
			return { total: 0, enviados: 0, fallidos: [], smtp_configurado: false };
		}

		const destinatarios = await obtenerCorreosModeracion();
		const ticket = construirTicketReporte(contexto.id);
		const tipoObjetivo = contexto.id_producto ? "Producto" : "Servicio";
		const nombreObjetivo = contexto.nombre_producto || contexto.nombre_servicio || "Sin nombre";
		const asunto = `[TultiMarket] Nuevo reporte ${ticket}`;
		const texto =
			`Se recibio un nuevo reporte.\n\n` +
			`Ticket: ${ticket}\n` +
			`Estado: ${contexto.estado_reporte}\n` +
			`Reportante: ${contexto.reportante_nombre || "N/D"} (${contexto.reportante_email || "sin correo"})\n` +
			`Reportado: ${contexto.usuario_reportado_nombre || "N/D"} (${contexto.usuario_reportado_email || "sin correo"})\n` +
			`Negocio: ${contexto.nombre_comercial || "N/D"}\n` +
			`${tipoObjetivo}: ${nombreObjetivo}\n` +
			`Motivo: ${contexto.motivo}\n` +
			`Descripcion: ${contexto.descripcion || "Sin descripcion"}\n`;
		const html =
			`<p>Se recibio un nuevo reporte.</p>` +
			`<p><strong>Ticket:</strong> ${escapeHtml(ticket)}</p>` +
			`<p><strong>Estado:</strong> ${escapeHtml(contexto.estado_reporte)}</p>` +
			`<p><strong>Reportante:</strong> ${escapeHtml(contexto.reportante_nombre || "N/D")} (${escapeHtml(contexto.reportante_email || "sin correo")})</p>` +
			`<p><strong>Reportado:</strong> ${escapeHtml(contexto.usuario_reportado_nombre || "N/D")} (${escapeHtml(contexto.usuario_reportado_email || "sin correo")})</p>` +
			`<p><strong>Negocio:</strong> ${escapeHtml(contexto.nombre_comercial || "N/D")}</p>` +
			`<p><strong>${escapeHtml(tipoObjetivo)}:</strong> ${escapeHtml(nombreObjetivo)}</p>` +
			`<p><strong>Motivo:</strong> ${escapeHtml(contexto.motivo)}</p>` +
			`<p><strong>Descripcion:</strong> ${escapeHtml(contexto.descripcion || "Sin descripcion")}</p>`;

		return intentarEnviarCorreos({ to: destinatarios, subject: asunto, text: texto, html });
	}

	// Crea un reporte nuevo desde la vista del comprador.
	// Solo permite reportar un producto o un servicio por solicitud.
	router.post("/comprador/reportes", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const { id_producto, id_servicio, motivo, descripcion } = req.body;
		const motivoFinal = String(motivo || "").trim();
		const descripcionFinal = String(descripcion || "").trim();
		const productoId = Number(id_producto);
		const servicioId = Number(id_servicio);
		const tieneProducto = Number.isInteger(productoId) && productoId > 0;
		const tieneServicio = Number.isInteger(servicioId) && servicioId > 0;

		if (tieneProducto === tieneServicio) {
			return res.status(400).json({
				mensaje: "Debes enviar solo id_producto o solo id_servicio",
			});
		}

		if (!motivoFinal || !descripcionFinal) {
			return res.status(400).json({
				mensaje: "Motivo y descripcion son obligatorios",
			});
		}

		if (descripcionFinal.length < 10) {
			return res.status(400).json({
				mensaje: "La descripcion debe tener al menos 10 caracteres",
			});
		}

		try {
			let idNegocio = null;
			let tipoObjetivo = null;

			if (tieneProducto) {
				const producto = await obtenerNegocioPorProducto(productoId);
				if (!producto) {
					return res.status(404).json({ mensaje: "Producto no encontrado" });
				}

				idNegocio = producto.id_negocio;
				tipoObjetivo = "producto";
			} else {
				const servicio = await obtenerNegocioPorServicio(servicioId);
				if (!servicio) {
					return res.status(404).json({ mensaje: "Servicio no encontrado" });
				}

				idNegocio = servicio.id_negocio;
				tipoObjetivo = "servicio";
			}

			const inserted = await pool.query(
				`INSERT INTO reportes (
					 id_usuario,
					 id_negocio,
					 id_producto,
					 id_servicio,
					 motivo,
					 descripcion,
					 estado_reporte
				 )
				 VALUES ($1, $2, $3, $4, $5, $6, 'PENDIENTE')
				 RETURNING id, id_usuario, id_negocio, id_producto, id_servicio, motivo, descripcion, estado_reporte, fecha_creacion, fecha_resolucion`,
				[
					idUsuario,
					idNegocio,
					tieneProducto ? productoId : null,
					tieneServicio ? servicioId : null,
					motivoFinal,
					descripcionFinal,
				]
			);

			let notificacionCorreo = { total: 0, enviados: 0, fallidos: [], smtp_configurado: false };
			try {
				notificacionCorreo = await notificarModeracionReporteCreado(inserted.rows[0].id);
			} catch (mailError) {
				console.error("No se pudo notificar a moderacion sobre el reporte:", mailError);
				notificacionCorreo = {
					total: 0,
					enviados: 0,
					fallidos: [{ email: null, error: String(mailError?.message || mailError) }],
					smtp_configurado: false,
				};
			}

			// ── Notificación in-app para admins (fire-and-forget) ──
			const nombreObjetivo = tipoObjetivo === "producto"
				? (await pool.query("SELECT nombre FROM productos WHERE id = $1", [productoId])).rows[0]?.nombre
				: (await pool.query("SELECT nombre FROM servicios WHERE id = $1", [servicioId])).rows[0]?.nombre;
			pool.query(
				`SELECT u.id FROM usuarios u INNER JOIN roles r ON r.id = u.id_rol WHERE u.activo = TRUE AND u.fecha_eliminacion IS NULL AND LOWER(r.nombre_rol) = 'admin'`
			).then((adminsResult) => {
				const adminIds = adminsResult.rows.map((r) => r.id);
				if (adminIds.length > 0) {
					notificarMultiples(pool, adminIds, {
						tipo: "nuevo_reporte",
						titulo: " Nuevo reporte recibido",
						mensaje: `Se reporto el ${tipoObjetivo} "${nombreObjetivo || "Sin nombre"}" por motivo: ${motivoFinal}.`,
						datos_extra: { reporte_id: inserted.rows[0].id, tipo_objetivo: tipoObjetivo, url: "/admin/reportes" },
					});
				}
			}).catch((err) => console.error("[notif] Error al notificar admins:", err.message));

			return res.status(201).json({
				mensaje: "Reporte creado",
				ticket: construirTicketReporte(inserted.rows[0].id),
				notificacion_correo: notificacionCorreo,
				reporte: {
					...inserted.rows[0],
					ticket: construirTicketReporte(inserted.rows[0].id),
					tipo_objetivo: tipoObjetivo,
				},
			});
		} catch (error) {
			console.error(error);
			return res.status(500).json({ mensaje: "Error al crear reporte" });
		}
	});

	// Devuelve todos los reportes creados por el comprador autenticado.
	router.get("/comprador/reportes", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		try {
			const result = await pool.query(
				`SELECT
					 r.id,
					 r.id_usuario,
					 r.id_negocio,
					 r.id_producto,
					 r.id_servicio,
					 r.motivo,
					 r.descripcion,
					 r.estado_reporte,
					 r.fecha_creacion,
					 r.fecha_resolucion,
					 p.nombre AS nombre_producto,
					 s.nombre AS nombre_servicio,
					 n.nombre_comercial
				 FROM reportes r
				 LEFT JOIN productos p ON p.id = r.id_producto
				 LEFT JOIN servicios s ON s.id = r.id_servicio
				 INNER JOIN negocios n ON n.id = r.id_negocio
				 WHERE r.id_usuario = $1
				 ORDER BY r.fecha_creacion DESC, r.id DESC`,
				[idUsuario]
			);

			return res.status(200).json(
				result.rows.map((reporte) => ({
					id: reporte.id,
					id_usuario: reporte.id_usuario,
					id_negocio: reporte.id_negocio,
					negocio: reporte.nombre_comercial,
					motivo: reporte.motivo,
					descripcion: reporte.descripcion,
					estado_reporte: reporte.estado_reporte,
					fecha_creacion: reporte.fecha_creacion,
					fecha_resolucion: reporte.fecha_resolucion,
					tipo_objetivo: reporte.id_producto ? "producto" : "servicio",
					id_objetivo: reporte.id_producto || reporte.id_servicio,
					nombre_objetivo: reporte.nombre_producto || reporte.nombre_servicio,
				}))
			);
		} catch (error) {
			console.error(error);
			return res.status(500).json({ mensaje: "Error al obtener reportes" });
		}
	});

	// Devuelve el detalle de un reporte específico del comprador autenticado.
	router.get("/comprador/reportes/:idReporte", async (req, res) => {
		const idUsuario = await requireActiveSession(req, res);
		if (!idUsuario) return;

		const idReporte = Number(req.params.idReporte);
		if (!Number.isInteger(idReporte) || idReporte <= 0) {
			return res.status(400).json({ mensaje: "idReporte invalido" });
		}

		try {
			const result = await pool.query(
				`SELECT
					 r.id,
					 r.id_usuario,
					 r.id_negocio,
					 r.id_producto,
					 r.id_servicio,
					 r.motivo,
					 r.descripcion,
					 r.estado_reporte,
					 r.fecha_creacion,
					 r.fecha_resolucion,
					 p.nombre AS nombre_producto,
					 s.nombre AS nombre_servicio,
					 n.nombre_comercial
				 FROM reportes r
				 LEFT JOIN productos p ON p.id = r.id_producto
				 LEFT JOIN servicios s ON s.id = r.id_servicio
				 INNER JOIN negocios n ON n.id = r.id_negocio
				 WHERE r.id = $1
					 AND r.id_usuario = $2
				 LIMIT 1`,
				[idReporte, idUsuario]
			);

			if (result.rows.length === 0) {
				return res.status(404).json({ mensaje: "Reporte no encontrado" });
			}

			const reporte = result.rows[0];
			return res.status(200).json({
				id: reporte.id,
				id_usuario: reporte.id_usuario,
				id_negocio: reporte.id_negocio,
				negocio: reporte.nombre_comercial,
				motivo: reporte.motivo,
				descripcion: reporte.descripcion,
				estado_reporte: reporte.estado_reporte,
				fecha_creacion: reporte.fecha_creacion,
				fecha_resolucion: reporte.fecha_resolucion,
				tipo_objetivo: reporte.id_producto ? "producto" : "servicio",
				id_objetivo: reporte.id_producto || reporte.id_servicio,
				nombre_objetivo: reporte.nombre_producto || reporte.nombre_servicio,
			});
		} catch (error) {
			console.error(error);
			return res.status(500).json({ mensaje: "Error al obtener reporte" });
		}
	});

	return router;
}

module.exports = createCompradorReportesRouter;

NODE_ENV=production
PORT=3000

# Frontend permitido para peticiones con sesion/cookies.
# Ejemplo: https://tultimarket-web.azurestaticapps.net
CORS_ORIGIN=https://TU-FRONTEND.azurewebsites.net

# Usa una cadena larga y privada en Azure.
SESSION_SECRET=cambia_esto_por_una_clave_larga
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# PostgreSQL en Azure. Puedes usar DATABASE_URL o las variables PG*.
PGHOST=TU-SERVIDOR.postgres.database.azure.com
PGPORT=5432
PGDATABASE=tultimarket
PGUSER=TU-USUARIO
PGPASSWORD=TU_PASSWORD
PGSSL=true

# Si el servicio de IA corre separado, cambia esta URL.
IA_BASE_URL=http://127.0.0.1:8000
IA_HOST=0.0.0.0
IA_PORT=8000
IA_RELOAD=false
OLLAMA_URL=http://localhost:11434/api/embeddings

# Carpeta local para imagenes subidas. En produccion conviene migrar a Blob Storage.
UPLOAD_DIR=static/images/products

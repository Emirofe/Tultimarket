const express = require("express");
const { crearNotificacion } = require("../Usuario/notificaciones-helper");

function createVendedorOrdersRouter({ pool }) {
	const router = express.Router();

	// Valida sesion de vendedor activa y deja el id de usuario en req para reutilizarlo.
	const requireVendedorAuth = async (req, res, next) => {
		const usuarioId = Number(req.session?.usuario_id || 0);
		const rol = String(req.session?.rol || "").toLowerCase();

		if (!Number.isInteger(usuarioId) || usuarioId <= 0) {
			return res.status(401).json({ status: "error", mensaje: "No autorizado" });
		}

		if (rol !== "vendedor") {
			return res.status(403).json({ status: "error", mensaje: "No autorizado para esta accion" });
		}

		try {
			const usuarioActivo = await pool.query(
				`SELECT u.id
				 FROM usuarios u
				 INNER JOIN roles r ON r.id = u.id_rol
				 WHERE u.id = $1
				   AND u.activo = TRUE
				   AND u.fecha_eliminacion IS NULL
				   AND LOWER(r.nombre_rol) = 'vendedor'
				 LIMIT 1`,
				[usuarioId]
			);

			if (usuarioActivo.rows.length === 0) {
				return res.status(401).json({ status: "error", mensaje: "Sesion invalida o usuario inactivo" });
			}
		} catch (error) {
			console.error("Error al validar sesion de vendedor:", error);
			return res.status(500).json({ status: "error", mensaje: "Error al validar sesion" });
		}

		req.vendedorId = usuarioId;
		return next();
	};

	const getNegocioId = async (req, res) => {
		const usuarioId = Number(req.vendedorId || req.session?.usuario_id || 0);
		if (!Number.isInteger(usuarioId) || usuarioId <= 0) {
			res.status(401).json({ status: "error", mensaje: "No autorizado" });
			return null;
		}

		const negocio = await pool.query(
			`SELECT id
			 FROM negocios
			 WHERE id_usuario = $1
			 ORDER BY fecha_creacion DESC, id DESC
			 LIMIT 1`,
			[usuarioId]
		);

		if (negocio.rows.length === 0) {
			res.status(404).json({ status: "error", mensaje: "Negocio no encontrado" });
			return null;
		}

		return negocio.rows[0].id;
	};

	function construirResumenCuponDesdeItems(items) {
		const cupones = new Map();

		for (const item of items) {
			const cupon = item?.snapshot?.cupon || null;
			if (!cupon?.codigo_cupon) continue;

			const codigo = String(cupon.codigo_cupon).trim().toUpperCase();
			if (!codigo) continue;

			const actual = cupones.get(codigo) || {
				codigo_cupon: codigo,
				porcentaje_descuento: Number(cupon.porcentaje_descuento) || 0,
				descuento_aplicado: 0,
				items_afectados: 0,
			};

			actual.descuento_aplicado += Number(cupon.descuento_aplicado) || 0;
			actual.items_afectados += 1;
			cupones.set(codigo, actual);
		}

		const resumenes = Array.from(cupones.values()).map((cupon) => ({
			...cupon,
			descuento_aplicado: Number(cupon.descuento_aplicado.toFixed(2)),
		}));

		if (resumenes.length === 0) return null;
		return resumenes.length === 1 ? resumenes[0] : resumenes;
	}

	// Lista pedidos que contienen items del negocio autenticado.
	router.get("/api/vendedor/pedidos", requireVendedorAuth, async (req, res) => {
		try {
			const negocioId = await getNegocioId(req, res);
			if (negocioId === null) return;

			const resultado = await pool.query(
				`SELECT
					p.id AS pedido_id,
					p.fecha_pedido,
					p.total,
					p.estado_pedido,
					p.direccion_envio_snapshot,
					u.nombre AS comprador_nombre,
					u.email AS comprador_email,
					u.telefono AS comprador_telefono,
					dp.id AS detalle_id,
					dp.id_producto,
					dp.id_servicio,
					dp.cantidad,
					dp.precio_unitario_historico,
					dp.snapshot_item,
					dp.id_agenda_seleccionada,
					ag.fecha_hora_inicio,
					ag.fecha_hora_fin,
					ag.estado AS agenda_estado,
					prod.nombre AS producto_nombre,
					srv.nombre AS servicio_nombre
				FROM pedidos p
				JOIN detalle_pedido dp ON p.id = dp.id_pedido
				LEFT JOIN agenda_servicios ag ON dp.id_agenda_seleccionada = ag.id
				LEFT JOIN productos prod ON dp.id_producto = prod.id
				LEFT JOIN servicios srv ON dp.id_servicio = srv.id
				JOIN usuarios u ON p.id_usuario = u.id
				WHERE (prod.id_negocio = $1 OR srv.id_negocio = $1)
				ORDER BY p.fecha_pedido DESC, dp.id ASC`,
				[negocioId]
			);

			const pedidosMap = new Map();

			for (const row of resultado.rows) {
				if (!pedidosMap.has(row.pedido_id)) {
					pedidosMap.set(row.pedido_id, {
						id: row.pedido_id,
						folio: `ORD-${row.pedido_id}`,
						date: row.fecha_pedido,
						buyerName: row.comprador_nombre,
						buyerEmail: row.comprador_email,
						buyerPhone: row.comprador_telefono,
						total: parseFloat(row.total),
						status: row.estado_pedido,
						address: row.direccion_envio_snapshot,
						cupon: null,
						items: [],
					});
				}

				const esProducto = row.id_producto !== null;
				const nameFromSnapshot = row.snapshot_item?.nombre || null;

				pedidosMap.get(row.pedido_id).items.push({
					id: esProducto ? row.id_producto : row.id_servicio,
					type: esProducto ? "producto" : "servicio",
					name: nameFromSnapshot || row.producto_nombre || row.servicio_nombre,
					quantity: Number(row.cantidad),
					price: parseFloat(row.precio_unitario_historico),
					subtotal: parseFloat(row.precio_unitario_historico) * Number(row.cantidad),
					snapshot: row.snapshot_item,
					agenda: row.id_agenda_seleccionada
						? {
							id_agenda: row.id_agenda_seleccionada,
							fecha_inicio: row.fecha_hora_inicio,
							fecha_fin: row.fecha_hora_fin,
							estado: row.agenda_estado,
						}
						: null,
					});
			}

			const pedidos = Array.from(pedidosMap.values());
			for (const pedido of pedidos) {
				pedido.cupon = construirResumenCuponDesdeItems(pedido.items);
			}

			return res.json({
				status: "success",
				pedidos,
			});
		} catch (error) {
			console.error("Error al obtener pedidos:", error);
			return res.status(500).json({ status: "error", mensaje: "Error al obtener los pedidos" });
		}
	});

	// Actualiza estado de un pedido del negocio, con validacion de transicion.
	router.put("/api/vendedor/pedidos/:pedidoId/estado", requireVendedorAuth, async (req, res) => {
		try {
			const pedidoId = Number(req.params.pedidoId);
			const estado = String(req.body?.estado || "")
				.trim()
				.replace(/_/g, " ");

			if (!Number.isInteger(pedidoId) || pedidoId <= 0) {
				return res.status(400).json({ status: "error", mensaje: "pedidoId invalido" });
			}

			const estadosPermitidos = ["PENDIENTE", "EN PREPARACION", "ENVIADO", "ENTREGADO", "CANCELADO"];
			const estadoNormalizado = estado.toUpperCase();

			if (!estadosPermitidos.includes(estadoNormalizado)) {
				return res.status(400).json({ status: "error", mensaje: "Estado no valido" });
			}

			const negocioId = await getNegocioId(req, res);
			if (negocioId === null) return;

			const client = await pool.connect();
			try {
				await client.query("BEGIN");

				const verification = await client.query(
					`SELECT p.id, p.estado_pedido
					 FROM pedidos p
					 WHERE p.id = $1
					   AND EXISTS (
						 SELECT 1
						 FROM detalle_pedido dp
						 LEFT JOIN productos prod ON dp.id_producto = prod.id
						 LEFT JOIN servicios srv ON dp.id_servicio = srv.id
						 WHERE dp.id_pedido = p.id
						   AND (prod.id_negocio = $2 OR srv.id_negocio = $2)
					   )
					 FOR UPDATE`,
					[pedidoId, negocioId]
				);

				if (verification.rows.length === 0) {
					await client.query("ROLLBACK");
					return res.status(403).json({
						status: "error",
						mensaje: "No tienes permiso para modificar este pedido",
					});
				}

				const estadoActual = String(verification.rows[0].estado_pedido || "").toUpperCase();
				const transicionesPermitidas = {
					PENDIENTE: ["EN PREPARACION", "CANCELADO"],
					"EN PREPARACION": ["ENVIADO", "CANCELADO"],
					ENVIADO: ["ENTREGADO"],
					ENTREGADO: [],
					CANCELADO: [],
				};

				if (estadoActual === estadoNormalizado) {
					await client.query("ROLLBACK");
					return res.status(400).json({
						status: "error",
						mensaje: "El pedido ya tiene ese estado",
					});
				}

				const permitidosDesdeEstadoActual = transicionesPermitidas[estadoActual] || [];
				if (!permitidosDesdeEstadoActual.includes(estadoNormalizado)) {
					await client.query("ROLLBACK");
					return res.status(400).json({
						status: "error",
						mensaje: `Transicion no permitida desde ${estadoActual} hacia ${estadoNormalizado}`,
					});
				}

				await client.query(
					`UPDATE pedidos
					 SET estado_pedido = $1
					 WHERE id = $2`,
					[estadoNormalizado, pedidoId]
				);

				if (estadoNormalizado === "CANCELADO") {
					const itemsProducto = await client.query(
						`SELECT id_producto, cantidad
						 FROM detalle_pedido
						 WHERE id_pedido = $1
						   AND id_producto IS NOT NULL`,
						[pedidoId]
					);

					for (const item of itemsProducto.rows) {
						const lote = await client.query(
							`SELECT id
							 FROM lotes_inventario
							 WHERE id_producto = $1
							   AND fecha_caducidad >= CURRENT_DATE
							 ORDER BY fecha_caducidad DESC
							 LIMIT 1`,
							[item.id_producto]
						);

						if (lote.rows.length > 0) {
							await client.query(
								`UPDATE lotes_inventario
								 SET stock_disponible = stock_disponible + $1
								 WHERE id = $2`,
								[item.cantidad, lote.rows[0].id]
							);
						} else {
							await client.query(
								`INSERT INTO lotes_inventario (id_producto, stock_disponible, fecha_recibido, fecha_caducidad)
								 VALUES ($1, $2, CURRENT_DATE, CURRENT_DATE + INTERVAL '1 year')`,
								[item.id_producto, item.cantidad]
							);
						}
					}

					await client.query(
						`UPDATE agenda_servicios
						 SET estado = 'disponible',
						     id_usuario_cliente = NULL
						 WHERE id IN (
						   SELECT dp.id_agenda_seleccionada
						   FROM detalle_pedido dp
						   WHERE dp.id_pedido = $1
						     AND dp.id_agenda_seleccionada IS NOT NULL
						 )`,
						[pedidoId]
					);
				}

				await client.query("COMMIT");
			} catch (txError) {
				await client.query("ROLLBACK");
				throw txError;
			} finally {
				client.release();
			}

			// ── Notificar al comprador sobre el cambio de estado (fire-and-forget) ──
			const estadoLabels = {
				"EN PREPARACION": { titulo: "Pedido en preparacion", emoji: "📦" },
				"ENVIADO": { titulo: "Pedido enviado", emoji: "🚚" },
				"ENTREGADO": { titulo: "Pedido entregado", emoji: "\u2705" },
				"CANCELADO": { titulo: "Pedido cancelado", emoji: "\u274c" },
			};
			const label = estadoLabels[estadoNormalizado];
			if (label) {
				pool.query(
					"SELECT id_usuario FROM pedidos WHERE id = $1",
					[pedidoId]
				).then((pedidoInfo) => {
					if (pedidoInfo.rows.length > 0) {
						crearNotificacion(pool, {
							id_usuario: pedidoInfo.rows[0].id_usuario,
							tipo: `pedido_${estadoNormalizado.toLowerCase().replace(/ /g, "_")}`,
							titulo: `${label.emoji} ${label.titulo}`,
							mensaje: `Tu pedido fue actualizado a: ${estadoNormalizado}.`,
							datos_extra: { pedido_id: pedidoId, url: `/mis-compras/${pedidoId}` },
						});
					}
				}).catch((err) => console.error("[notif] Error:", err.message));
			}

			return res.json({ status: "success", mensaje: "Estado del pedido actualizado correctamente" });
		} catch (error) {
			console.error("Error al actualizar estado del pedido:", error);
			return res.status(500).json({ status: "error", mensaje: "Error al actualizar el estado del pedido" });
		}
	});

	// Devuelve metricas por estado y ventas de los ultimos 6 meses del negocio.
	router.get("/api/vendedor/pedidos/estadisticas", requireVendedorAuth, async (req, res) => {
		try {
			const negocioId = await getNegocioId(req, res);
			if (negocioId === null) return;

			const statsByStatus = await pool.query(
				`SELECT
					p.estado_pedido,
					COUNT(DISTINCT p.id) AS cantidad,
					SUM(dp.cantidad * dp.precio_unitario_historico) AS total_ventas
				FROM pedidos p
				JOIN detalle_pedido dp ON p.id = dp.id_pedido
				LEFT JOIN productos prod ON dp.id_producto = prod.id
				LEFT JOIN servicios srv ON dp.id_servicio = srv.id
				WHERE (prod.id_negocio = $1 OR srv.id_negocio = $1)
				  AND p.estado_pedido != 'CANCELADO'
				GROUP BY p.estado_pedido`,
				[negocioId]
			);

			const monthlySales = await pool.query(
				`SELECT
					DATE_TRUNC('month', p.fecha_pedido) AS mes,
					COUNT(DISTINCT p.id) AS cantidad_pedidos,
					SUM(dp.cantidad * dp.precio_unitario_historico) AS total_ventas
				FROM pedidos p
				JOIN detalle_pedido dp ON p.id = dp.id_pedido
				LEFT JOIN productos prod ON dp.id_producto = prod.id
				LEFT JOIN servicios srv ON dp.id_servicio = srv.id
				WHERE (prod.id_negocio = $1 OR srv.id_negocio = $1)
					AND p.estado_pedido != 'CANCELADO'
					AND p.fecha_pedido >= NOW() - INTERVAL '6 months'
				GROUP BY DATE_TRUNC('month', p.fecha_pedido)
				ORDER BY mes DESC`,
				[negocioId]
			);

			return res.json({
				status: "success",
				estadisticas: {
					por_estado: statsByStatus.rows,
					ventas_mensuales: monthlySales.rows,
					total_pedidos: statsByStatus.rows.reduce((sum, row) => sum + parseInt(row.cantidad, 10), 0),
					total_ventas: statsByStatus.rows.reduce(
						(sum, row) => sum + parseFloat(row.total_ventas || 0),
						0
					),
				},
			});
		} catch (error) {
			console.error("Error al obtener estadísticas:", error);
			return res.status(500).json({ status: "error", mensaje: "Error al obtener estadísticas" });
		}
	});

	return router;
}

module.exports = createVendedorOrdersRouter;
